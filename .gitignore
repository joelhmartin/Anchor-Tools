/.DS_Store
/.env

# Locally-built minified assets — generated by bin/build-assets.mjs and by the
# release workflow. Never committed; the release ZIP carries them.
*.min.css
*.min.js
*.min.js.map

# Node deps from running the build script locally
/node_modules/

# Playwright / wp-env E2E artifacts
/playwright-report/
/test-results/
/e2e/.seed.json

# PHPUnit run cache
/.phpunit.result.cache

# Composer DEV dependencies (installed by `composer install`, not shipped).
# The repo intentionally tracks the PROD vendor deps; these dev-only packages
# must never be committed. The release workflow runs `composer install --no-dev`.
/vendor/bin/
/vendor/doctrine/
/vendor/myclabs/
/vendor/nikic/
/vendor/phar-io/
/vendor/phpunit/
/vendor/sebastian/
/vendor/theseer/
/vendor/yoast/
