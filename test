<script>
var __mm_scrollY = 0;
function lockBodyScroll(){
  __mm_scrollY = window.scrollY || document.documentElement.scrollTop || 0;
  document.body.classList.add("mm-locked");
  document.documentElement.classList.add("mm-locked");
  document.body.style.top = "-" + __mm_scrollY + "px";
}
function unlockBodyScroll(){
  document.body.classList.remove("mm-locked");
  document.documentElement.classList.remove("mm-locked");
  var y = __mm_scrollY;
  document.body.style.top = "";
  window.scrollTo(0, y);
}
function toggleMobileSubGroup(el){
  var group = el.closest('.mobile-sub-group');
  var wasActive = group.classList.contains('active');
  group.parentElement.querySelectorAll('.mobile-sub-group').forEach(function(s){ s.classList.remove('active'); });
  if(!wasActive) group.classList.add('active');
}
function toggleContent(iconElement){
  var container = iconElement.parentElement.parentElement;
  var wasActive = container.classList.contains("active");
  var siblings = container.parentElement.querySelectorAll(".menu-toggle-container");
  siblings.forEach(function(s){ s.classList.remove("active"); });
  if(!wasActive) container.classList.add("active");
}
function toggleMobileMenu(el){
  var overlay = document.querySelector(".mobile-menu-overlay");
  var headerSection = document.querySelector(".anchor-header-section");
  var play = document.querySelector(".play-icon");
  var willOpen = !overlay.classList.contains("active");
  el.classList.toggle("active", willOpen);
  overlay.classList.toggle("active", willOpen);
  if (willOpen) {
    if (headerSection){ headerSection.classList.remove("hide"); headerSection.classList.remove("show"); }
    lockBodyScroll();
    if (play){ play.classList.remove("active"); void play.offsetWidth; play.classList.add("active"); setTimeout(function(){ play.classList.remove("active"); },1500); }
  } else {
    unlockBodyScroll();
    document.querySelectorAll(".menu-toggle-container.active").forEach(function(c){ c.classList.remove("active"); });
  }
}
document.addEventListener("keydown", function(e){
  if (e.key === "Escape") {
    var overlay = document.querySelector(".mobile-menu-overlay");
    var btn = document.querySelector(".burger-container");
    if (overlay && overlay.classList.contains("active")) toggleMobileMenu(btn);
  }
});
document.addEventListener("DOMContentLoaded", function () {
  if (window.location.pathname.replace(/\/$/, "") === "/plans") {
    var header = document.querySelector(".anchor-header-section");
    if (header) {
      header.style.setProperty("position", "absolute", "important");
      header.style.setProperty("paddingTop", "0px", "important");
      var observer = new MutationObserver(function(){
        header.style.setProperty("position", "absolute", "important");
        header.style.setProperty("paddingTop", "0px", "important");
      });
      observer.observe(header, { attributes: true, attributeFilter: ["style"] });
    }
    return;
  }
  var headerRow = document.querySelector(".anchor-header-row");
  var headerSection = document.querySelector(".anchor-header-section");
  var lastScrollTop = 0;
  var lastHideScroll = 0;
  window.addEventListener("scroll", function () {
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    if (scrollTop > 200) { headerRow.classList.add("active"); } else { headerRow.classList.remove("active"); }
    if (scrollTop <= 0) {
      headerSection.classList.add("show"); headerSection.classList.remove("hide"); lastHideScroll = 0;
    } else if (scrollTop > lastScrollTop) {
      headerSection.classList.add("hide"); headerSection.classList.remove("show"); lastHideScroll = scrollTop;
    } else {
      if (lastHideScroll - scrollTop > 50) { headerSection.classList.add("show"); headerSection.classList.remove("hide"); }
    }
    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
  });
});
</script>

